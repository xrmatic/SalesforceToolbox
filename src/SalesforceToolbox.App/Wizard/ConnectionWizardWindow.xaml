<mah:MetroWindow x:Class="SalesforceToolbox.App.Wizard.ConnectionWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:pages="clr-namespace:SalesforceToolbox.App.Wizard.Pages"
        Title="Connect to Salesforce"
        Height="500" Width="640"
        WindowStartupLocation="CenterOwner"
        ShowMinButton="False"
        ShowMaxRestoreButton="False"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Wizard page content -->
        <Border Grid.Row="0" Padding="0">
            <ContentControl x:Name="PageContent" />
        </Border>

        <!-- Navigation buttons -->
        <Border Grid.Row="1"
                BorderBrush="{DynamicResource MahApps.Brushes.Gray9}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <DockPanel>
                <!-- Step indicator -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="StepIndicator"
                               Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BackButton" Content="Back"
                            Width="80" Margin="0,0,8,0"
                            Click="BackButton_Click" />
                    <Button x:Name="NextButton" Content="Next"
                            Width="80" Margin="0,0,8,0"
                            Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                            Click="NextButton_Click" />
                    <Button x:Name="CancelButton" Content="Cancel"
                            Width="80"
                            Click="CancelButton_Click" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</mah:MetroWindow>
