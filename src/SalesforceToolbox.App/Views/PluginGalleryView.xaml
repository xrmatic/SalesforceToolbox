<UserControl x:Class="SalesforceToolbox.App.Views.PluginGalleryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Plugin list -->
        <Border Grid.Column="0"
                BorderBrush="{DynamicResource MahApps.Brushes.Gray9}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="Plugins"
                           FontSize="18" FontWeight="SemiBold"
                           Margin="12,12,12,8"
                           Foreground="{DynamicResource MahApps.Brushes.Text}" />
                <ListBox ItemsSource="{Binding Plugins}"
                         SelectedItem="{Binding SelectedPlugin, Mode=TwoWay}"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4,6">
                                <Border Width="36" Height="36"
                                        Background="{DynamicResource MahApps.Brushes.Accent}"
                                        CornerRadius="4" Margin="0,0,10,0">
                                    <iconPacks:PackIconMaterial Kind="PuzzleOutline"
                                                                Width="20" Height="20"
                                                                Foreground="White"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource MahApps.Brushes.Text}" />
                                    <TextBlock Text="{Binding Description}"
                                               FontSize="11"
                                               Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="160" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Plugin content -->
        <Grid Grid.Column="1">
            <TextBlock Text="Select a plugin from the list"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       FontSize="16"
                       Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                       Visibility="{Binding PluginView, Converter={StaticResource NullToVisibilityConverter}}" />
            <ContentPresenter Content="{Binding PluginView}" />
        </Grid>
    </Grid>
</UserControl>
