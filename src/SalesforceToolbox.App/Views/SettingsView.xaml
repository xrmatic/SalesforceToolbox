<UserControl x:Class="SalesforceToolbox.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" MaxWidth="600">
            <TextBlock Text="Settings" FontSize="24" FontWeight="Light" Margin="0,0,0,20" />

            <GroupBox Header="Connection Profiles">
                <StackPanel Margin="0,8">
                    <TextBlock Text="Manage saved Salesforce connection profiles."
                               Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                               Margin="0,0,0,8" />
                    <Button Content="Manage Profiles"
                            Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                            HorizontalAlignment="Left" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Theme" Margin="0,12,0,0">
                <StackPanel Margin="0,8">
                    <TextBlock Text="Choose application theme accent color."
                               Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                               Margin="0,0,0,8" />
                    <ComboBox Width="200" HorizontalAlignment="Left">
                        <ComboBoxItem Content="Blue (Default)" IsSelected="True" />
                        <ComboBoxItem Content="Red" />
                        <ComboBoxItem Content="Green" />
                        <ComboBoxItem Content="Purple" />
                        <ComboBoxItem Content="Orange" />
                    </ComboBox>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="About" Margin="0,12,0,0">
                <StackPanel Margin="0,8">
                    <TextBlock Text="Salesforce Toolbox" FontWeight="SemiBold" />
                    <TextBlock Text="Version 1.0.0" Foreground="{DynamicResource MahApps.Brushes.Gray3}" />
                    <TextBlock Text="A modular desktop toolbox for Salesforce administrators and developers."
                               Margin="0,4,0,0"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource MahApps.Brushes.Gray3}" />
                </StackPanel>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
