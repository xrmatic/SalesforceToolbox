<UserControl x:Class="SalesforceToolbox.Plugin.UserManagement.Views.UserDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16" DataContext="{Binding SelectedUser}">
            <TextBlock Text="User Details" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" FontWeight="SemiBold" Margin="0,4" />
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Name}" Margin="0,4" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Username:" FontWeight="SemiBold" Margin="0,4" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Username}" Margin="0,4" />
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Email:" FontWeight="SemiBold" Margin="0,4" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Email}" Margin="0,4" />
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Profile:" FontWeight="SemiBold" Margin="0,4" />
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Profile.Name}" Margin="0,4" />
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Active:" FontWeight="SemiBold" Margin="0,4" />
                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding IsActive}" Margin="0,4" />
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Last Login:" FontWeight="SemiBold" Margin="0,4" />
                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding LastLoginDate, StringFormat=\{0:yyyy-MM-dd HH:mm\}}" Margin="0,4" />
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
