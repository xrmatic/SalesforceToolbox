<UserControl x:Class="SalesforceToolbox.Plugin.ObjectExplorer.Views.ObjectListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Object list panel -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <DockPanel Grid.Row="0" Margin="8,8,8,4">
                <TextBlock Text="Objects" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button DockPanel.Dock="Right" Command="{Binding RefreshCommand}"
                        Style="{DynamicResource MahApps.Styles.Button.Square}"
                        Width="32" Height="32" HorizontalAlignment="Right">
                    <iconPacks:PackIconMaterial Kind="Refresh" Width="16" Height="16" />
                </Button>
            </DockPanel>
            <mah:MetroTextBox Grid.Row="1" Margin="8,0,8,4"
                              mah:TextBoxHelper.Watermark="Filter objects..."
                              mah:TextBoxHelper.ClearTextButton="True"
                              Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
            <ListBox Grid.Row="2"
                     ItemsSource="{Binding FilteredObjects}"
                     SelectedItem="{Binding SelectedObject, Mode=TwoWay}"
                     BorderThickness="0,1,1,0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4,3">
                            <TextBlock Text="{Binding Label}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Name}" FontSize="10"
                                       Foreground="{DynamicResource MahApps.Brushes.Gray3}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- Object detail panel -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="12,8"
                    BorderBrush="{DynamicResource MahApps.Brushes.Gray9}"
                    BorderThickness="0,0,0,1"
                    Visibility="{Binding SelectedObjectDetail, Converter={x:Null}}">
                <StackPanel>
                    <TextBlock Text="{Binding SelectedObjectDetail.Label}"
                               FontSize="20" FontWeight="Light" />
                    <TextBlock Text="{Binding SelectedObjectDetail.Name}"
                               FontSize="12" Foreground="{DynamicResource MahApps.Brushes.Gray3}" />
                </StackPanel>
            </Border>

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding SelectedObjectDetail.Fields}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      GridLinesVisibility="Horizontal"
                      Margin="8,4">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Label" Binding="{Binding Label}" Width="160" />
                    <DataGridTextColumn Header="API Name" Binding="{Binding Name}" Width="160" />
                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="100" />
                    <DataGridTextColumn Header="Length" Binding="{Binding Length}" Width="60" />
                    <DataGridCheckBoxColumn Header="Required" Binding="{Binding IsNillable, Converter={x:Null}}" Width="70" />
                    <DataGridCheckBoxColumn Header="Custom" Binding="{Binding IsCustom}" Width="60" />
                    <DataGridCheckBoxColumn Header="Unique" Binding="{Binding IsUnique}" Width="60" />
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock Grid.Row="2" Text="{Binding StatusMessage}"
                       Margin="8,4" FontSize="11"
                       Foreground="{DynamicResource MahApps.Brushes.Gray3}" />
        </Grid>

        <!-- Loading overlay -->
        <mah:ProgressRing Grid.Column="0" Grid.ColumnSpan="2"
                          IsActive="{Binding IsLoading}"
                          Width="60" Height="60"
                          Panel.ZIndex="10"
                          HorizontalAlignment="Center" VerticalAlignment="Center" />
    </Grid>
</UserControl>
