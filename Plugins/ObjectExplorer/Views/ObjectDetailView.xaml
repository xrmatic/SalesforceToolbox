<UserControl x:Class="SalesforceToolbox.Plugin.ObjectExplorer.Views.ObjectDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">
            <TextBlock Text="Object Details" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
            <TextBlock Text="{Binding SelectedObjectDetail.Name}" />
            <TextBlock Text="{Binding SelectedObjectDetail.Label}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
